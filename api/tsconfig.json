{
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "baseUrl": "./",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@api/*": ["src/*", "*"]
    },
    "types": ["node"],
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules"]
}
